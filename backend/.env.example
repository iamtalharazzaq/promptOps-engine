# ---------------------------------------------------------------
# GhostAI Lite — Backend Environment Variables
# ---------------------------------------------------------------
# Copy this file to .env and adjust values for your local setup.
# All variables have sensible defaults, so zero-config works OOTB.
# ---------------------------------------------------------------

# HTTP server port
PORT=8080

# Ollama API base URL (local instance)
OLLAMA_HOST=http://localhost:11434

# Default model to use for inference
# Run `ollama pull tinyllama` to download this model first.
OLLAMA_MODEL=tinyllama

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
